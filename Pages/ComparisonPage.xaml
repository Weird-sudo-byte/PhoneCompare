<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pm="clr-namespace:PhoneCompare.PageModels"
             x:Class="PhoneCompare.Pages.ComparisonPage"
             x:DataType="pm:ComparisonPageModel"
             x:Name="ThisPage"
             Title="Compare"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Path=BindingContext, Source={x:Reference ThisPage}, x:DataType=ContentPage}"
            EventName="Appearing" Command="{Binding AppearingCommand}"/>
    </ContentPage.Behaviors>

    <Grid RowDefinitions="*">

        <!-- Loading -->
        <ActivityIndicator Grid.Row="0" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center"
                           WidthRequest="48" HeightRequest="48"/>

        <!-- Error Banner -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="14,10"
                BackgroundColor="{StaticResource LoserRed}" Margin="12" VerticalOptions="Start"
                IsVisible="{Binding ErrorMessage, Converter={toolkit:IsStringNotNullOrEmptyConverter}}">
            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource LoserRedText}" FontSize="13"/>
        </Border>

        <ScrollView Grid.Row="0" IsVisible="{Binding HasBothPhones}">
            <VerticalStackLayout Spacing="0">

                <!-- Hero Section with VS -->
                <Grid HeightRequest="280" Padding="16,20">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0"/>
                            <GradientStop Color="{StaticResource Secondary}" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <!-- Phone 1 -->
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="8">
                            <Border WidthRequest="100" HeightRequest="130" StrokeShape="RoundRectangle 16"
                                    BackgroundColor="White" Stroke="Transparent" HorizontalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,4" Radius="12" Opacity="0.2"/>
                                </Border.Shadow>
                                <Image Source="{Binding Phone1.ImageUrl}" Aspect="AspectFit" Margin="8"/>
                            </Border>
                            <Label Text="{Binding Phone1.Name}" FontSize="12" FontAttributes="Bold"
                                   TextColor="White" HorizontalTextAlignment="Center" MaxLines="2"
                                   LineBreakMode="TailTruncation"/>
                            <Border StrokeShape="RoundRectangle 12" Padding="10,4" HorizontalOptions="Center"
                                    BackgroundColor="#66000000" Stroke="Transparent">
                                <Label Text="{Binding Phone1Wins, StringFormat='{0} wins'}" FontSize="11"
                                       TextColor="White" FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                        
                        <!-- VS Badge -->
                        <Grid Grid.Column="1" VerticalOptions="Center">
                            <Border WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28"
                                    BackgroundColor="White" Stroke="Transparent">
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,4" Radius="10" Opacity="0.3"/>
                                </Border.Shadow>
                                <Label Text="VS" FontSize="18" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                        
                        <!-- Phone 2 -->
                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="8">
                            <Border WidthRequest="100" HeightRequest="130" StrokeShape="RoundRectangle 16"
                                    BackgroundColor="White" Stroke="Transparent" HorizontalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,4" Radius="12" Opacity="0.2"/>
                                </Border.Shadow>
                                <Image Source="{Binding Phone2.ImageUrl}" Aspect="AspectFit" Margin="8"/>
                            </Border>
                            <Label Text="{Binding Phone2.Name}" FontSize="12" FontAttributes="Bold"
                                   TextColor="White" HorizontalTextAlignment="Center" MaxLines="2"
                                   LineBreakMode="TailTruncation"/>
                            <Border StrokeShape="RoundRectangle 12" Padding="10,4" HorizontalOptions="Center"
                                    BackgroundColor="#66000000" Stroke="Transparent">
                                <Label Text="{Binding Phone2Wins, StringFormat='{0} wins'}" FontSize="11"
                                       TextColor="White" FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Grid>

                <!-- Winner Announcement Card -->
                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent" Margin="12,-30,12,0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource BlackBrush}" Offset="0,4" Radius="16" Opacity="0.12"/>
                    </Border.Shadow>
                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24"
                                BackgroundColor="{AppThemeBinding Light=#FEF3C7, Dark=#78350F}" Stroke="Transparent">
                            <Label Text="🏆" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding OverallWinner}" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                            <Label Text="{Binding WinnerSummary}" FontSize="12" TextColor="{StaticResource Gray400}"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="📤" Command="{Binding ShareCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                                TextColor="{StaticResource Primary}" FontSize="18"
                                WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="0"/>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <VerticalStackLayout Padding="12,16" Spacing="16"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}">

                <!-- Key Specs Visual Comparison -->
                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource BlackBrush}" Offset="0,2" Radius="8" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚡" FontSize="16"/>
                            <Label Text="Key Specs Comparison" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                        </HorizontalStackLayout>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding KeySpecs}" Spacing="16">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="pm:SpecBar">
                                    <Border StrokeShape="RoundRectangle 12" Padding="12"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                                            Stroke="Transparent">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                            <!-- Spec Label -->
                                            <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                                <Label Text="{Binding Icon}" FontSize="18"/>
                                                <Label Text="{Binding Label}" FontSize="13" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                            <!-- Phone 1 Bar -->
                                            <Grid Grid.Row="1" ColumnDefinitions="80,*,Auto" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="{Binding Display1}" FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                                                <Grid Grid.Column="1" HeightRequest="20">
                                                    <Border StrokeShape="RoundRectangle 6" 
                                                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                                                            Stroke="Transparent"/>
                                                    <Border StrokeShape="RoundRectangle 6" HorizontalOptions="Start"
                                                            Stroke="Transparent"
                                                            WidthRequest="{Binding Percent1, Converter={StaticResource PercentToWidth}}">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="{StaticResource Primary}" Offset="0"/>
                                                                <GradientStop Color="#818CF8" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                                <Label Grid.Column="2" Text="✓" FontSize="14" FontAttributes="Bold"
                                                       TextColor="#10B981" VerticalOptions="Center"
                                                       IsVisible="{Binding IsPhone1Winner}"/>
                                            </Grid>
                                            <!-- Phone 2 Bar -->
                                            <Grid Grid.Row="2" ColumnDefinitions="80,*,Auto" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="{Binding Display2}" FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource Secondary}" VerticalOptions="Center"/>
                                                <Grid Grid.Column="1" HeightRequest="20">
                                                    <Border StrokeShape="RoundRectangle 6" 
                                                            BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                                                            Stroke="Transparent"/>
                                                    <Border StrokeShape="RoundRectangle 6" HorizontalOptions="Start"
                                                            Stroke="Transparent"
                                                            WidthRequest="{Binding Percent2, Converter={StaticResource PercentToWidth}}">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="{StaticResource Secondary}" Offset="0"/>
                                                                <GradientStop Color="#FDBA74" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                                <Label Grid.Column="2" Text="✓" FontSize="14" FontAttributes="Bold"
                                                       TextColor="#10B981" VerticalOptions="Center"
                                                       IsVisible="{Binding IsPhone2Winner}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Detailed Specifications -->
                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Padding="0" Margin="0,8,0,0">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource BlackBrush}" Offset="0,2" Radius="8" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <!-- Header -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*"
                              BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="📋" FontSize="16"/>
                                <Label Text="Full Specifications" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"/>
                        
                        <!-- Specs Table -->
                        <CollectionView ItemsSource="{Binding Rows}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="pm:ComparisonRow">
                                    <VerticalStackLayout Spacing="0">
                                        <!-- Section Header -->
                                        <Border StrokeShape="Rectangle" Stroke="Transparent" Padding="14,12"
                                                IsVisible="{Binding IsHeader}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="{StaticResource Primary}" Offset="0"/>
                                                    <GradientStop Color="#818CF8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Label Text="{Binding Label}" FontSize="13" FontAttributes="Bold" TextColor="White"/>
                                        </Border>
                                        <!-- Spec Row -->
                                        <Grid ColumnDefinitions="90,*,*" Padding="0" MinimumHeightRequest="44"
                                              BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                              IsVisible="{Binding IsHeader, Converter={toolkit:InvertedBoolConverter}}">
                                            <!-- Spec Key -->
                                            <Border Grid.Column="0" StrokeShape="Rectangle" Stroke="Transparent" Padding="12,10"
                                                    BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                                                <Label Text="{Binding Label}" FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                                            </Border>
                                            <!-- Phone 1 Value -->
                                            <Border Grid.Column="1" StrokeShape="Rectangle" Stroke="Transparent" Padding="10,10"
                                                    BackgroundColor="{Binding Val1Background}">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Border Grid.Column="0" WidthRequest="18" HeightRequest="18"
                                                            StrokeShape="RoundRectangle 9" Stroke="Transparent"
                                                            BackgroundColor="#10B981" VerticalOptions="Start"
                                                            IsVisible="{Binding IsPhone1Winner}">
                                                        <Label Text="✓" FontSize="10" TextColor="White"
                                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Label Grid.Column="1" Text="{Binding Val1}" FontSize="11"
                                                           TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                                           LineBreakMode="WordWrap" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                            <!-- Phone 2 Value -->
                                            <Border Grid.Column="2" StrokeShape="Rectangle" Stroke="Transparent" Padding="10,10"
                                                    BackgroundColor="{Binding Val2Background}">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                    <Border Grid.Column="0" WidthRequest="18" HeightRequest="18"
                                                            StrokeShape="RoundRectangle 9" Stroke="Transparent"
                                                            BackgroundColor="#10B981" VerticalOptions="Start"
                                                            IsVisible="{Binding IsPhone2Winner}">
                                                        <Label Text="✓" FontSize="10" TextColor="White"
                                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Label Grid.Column="1" Text="{Binding Val2}" FontSize="11"
                                                           TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                                           LineBreakMode="WordWrap" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                            <!-- Bottom border -->
                                            <BoxView Grid.ColumnSpan="3" HeightRequest="1" VerticalOptions="End"
                                                     Color="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                </VerticalStackLayout>

                <BoxView HeightRequest="100" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
