<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pm="clr-namespace:PhoneCompare.PageModels"
             x:Class="PhoneCompare.Pages.ForgotPasswordPage"
             x:DataType="pm:ForgotPasswordPageModel"
             Shell.NavBarIsVisible="False"
             Title="Forgot Password">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="20" VerticalOptions="Center">

            <!-- Brand -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,0,0,16">
                <Border WidthRequest="72" HeightRequest="72"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 20" Stroke="Transparent"
                        HorizontalOptions="Center">
                    <Label Text="🔑" TextColor="White" FontSize="32"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Reset Password" FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                <Label Text="We'll help you get back in" FontSize="13"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Gray400}"/>
            </VerticalStackLayout>

            <!-- Card -->
            <Border StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkSecondaryBackground}}">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,4" Radius="20" Opacity="0.1"/>
                </Border.Shadow>
                <VerticalStackLayout Padding="24" Spacing="16">

                    <!-- Step 1: Email Input -->
                    <VerticalStackLayout Spacing="16" IsVisible="{Binding ShowEmailStep}">
                        <Label Text="Enter your email" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                        <Label Text="We'll send you a verification code to reset your password."
                               FontSize="13" TextColor="{StaticResource Gray400}"/>

                        <Border StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="14,4"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                                HeightRequest="52">
                            <Entry Placeholder="Email" Text="{Binding Email}"
                                   Keyboard="Email" BackgroundColor="Transparent"
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                   VerticalOptions="Center" FontSize="14"/>
                        </Border>

                        <Button Text="Send Code" Command="{Binding SendOtpCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontAttributes="Bold" CornerRadius="14" HeightRequest="52"
                                FontSize="15" Margin="0,6,0,0"/>
                    </VerticalStackLayout>

                    <!-- Step 2: OTP Verification -->
                    <VerticalStackLayout Spacing="16" IsVisible="{Binding ShowOtpStep}">
                        <Label Text="Verify your email" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                        <Label Text="{Binding StatusMessage}" FontSize="13" TextColor="{StaticResource Gray400}"/>

                        <Border StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="14,4"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                                HeightRequest="52">
                            <Entry Placeholder="6-digit code" Text="{Binding OtpCode}"
                                   Keyboard="Numeric" BackgroundColor="Transparent"
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                   VerticalOptions="Center" FontSize="14" MaxLength="6"/>
                        </Border>

                        <Button Text="Verify &amp; Send Reset Link" Command="{Binding VerifyOtpCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontAttributes="Bold" CornerRadius="14" HeightRequest="52"
                                FontSize="15"/>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="Didn't receive the code?" TextColor="{StaticResource Gray400}" FontSize="13"/>
                            <Label Text="Resend" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource Primary}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ResendOtpCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <Label Text="← Back" FontSize="13" TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BackToEmailCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}" TextColor="#E53935" FontSize="12"
                           IsVisible="{Binding ErrorMessage, Converter={toolkit:IsStringNotNullOrEmptyConverter}}"/>

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" HorizontalOptions="Center"/>

                </VerticalStackLayout>
            </Border>

            <!-- Back to Login -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Remember your password?" TextColor="{StaticResource Gray400}" FontSize="13"/>
                <Label Text="Sign In" FontAttributes="Bold" FontSize="13"
                       TextColor="{StaticResource Primary}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
