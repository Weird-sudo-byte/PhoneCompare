<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pm="clr-namespace:PhoneCompare.PageModels"
             x:Class="PhoneCompare.Pages.LoginPage"
             x:DataType="pm:LoginPageModel"
             Shell.NavBarIsVisible="False"
             Title="Login">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="20" VerticalOptions="Center">

            <!-- Brand -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,16">
                <Image Source="logo.svg" WidthRequest="80" HeightRequest="80"
                       HorizontalOptions="Center"/>
                <Label Text="PhoneCompare" FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                <Label Text="Find your perfect phone ⚡" FontSize="13"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Gray400}"/>
            </VerticalStackLayout>

            <!-- Card -->
            <Border StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkSecondaryBackground}}">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,4" Radius="20" Opacity="0.1"/>
                </Border.Shadow>
                <VerticalStackLayout Padding="24" Spacing="16">

                    <Label Text="Welcome back" FontSize="18" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>

                    <!-- Email -->
                    <Border StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="14,4"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                            HeightRequest="52">
                        <Entry Placeholder="Email" Text="{Binding Email}"
                               Keyboard="Email" BackgroundColor="Transparent"
                               PlaceholderColor="{StaticResource Gray400}"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                               VerticalOptions="Center" FontSize="14"/>
                    </Border>

                    <!-- Password -->
                    <Border StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="14,4"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                            HeightRequest="52">
                        <Entry Placeholder="Password" Text="{Binding Password}"
                               IsPassword="True" BackgroundColor="Transparent"
                               PlaceholderColor="{StaticResource Gray400}"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                               VerticalOptions="Center" FontSize="14"/>
                    </Border>

                    <!-- Forgot Password -->
                    <Label Text="Forgot Password?" FontSize="13" TextColor="{StaticResource Primary}"
                           HorizontalOptions="End" Margin="0,-8,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Error -->
                    <Label Text="{Binding ErrorMessage}" TextColor="#E53935" FontSize="12"
                           IsVisible="{Binding ErrorMessage, Converter={toolkit:IsStringNotNullOrEmptyConverter}}"/>

                    <!-- Login Button -->
                    <Button Text="Sign In" Command="{Binding LoginCommand}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            FontAttributes="Bold" CornerRadius="14" HeightRequest="52"
                            FontSize="15" Margin="0,6,0,0"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Register link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Don't have an account?" TextColor="{StaticResource Gray400}" FontSize="13"/>
                <Label Text="Register" FontAttributes="Bold" FontSize="13"
                       TextColor="{StaticResource Primary}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
