<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pm="clr-namespace:PhoneCompare.PageModels"
             xmlns:models="clr-namespace:PhoneCompare.Models"
             xmlns:services="clr-namespace:PhoneCompare.Services"
             x:Class="PhoneCompare.Pages.PhoneListPage"
             x:DataType="pm:PhoneListPageModel"
             x:Name="ThisPage"
             Title="Phones"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Path=BindingContext, Source={x:Reference ThisPage}, x:DataType=ContentPage}"
            EventName="Appearing" Command="{Binding AppearingCommand}"/>
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header Bar -->
        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="Rectangle"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
            <Border.Shadow>
                <Shadow Brush="{StaticResource BlackBrush}" Offset="0,2" Radius="4" Opacity="0.08"/>
            </Border.Shadow>
            <Grid Padding="16,14" ColumnDefinitions="*,Auto,Auto,Auto">
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Image Source="logo.svg" WidthRequest="32" HeightRequest="32"/>
                    <Label Text="PhoneCompare" FontSize="17" FontAttributes="Bold" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                           MaxLines="1" LineBreakMode="TailTruncation"/>
                </HorizontalStackLayout>
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" WidthRequest="20" HeightRequest="20"
                                   VerticalOptions="Center" Margin="0,0,8,0"/>
                <!-- Find My Phone pill button -->
                <Border Grid.Column="2" StrokeShape="RoundRectangle 16" Padding="10,6"
                        BackgroundColor="{StaticResource Primary}" Stroke="Transparent"
                        VerticalOptions="Center" Margin="0,0,10,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToQuizCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="🎯 Find My Phone" FontSize="12" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center"/>
                </Border>
                <Label Grid.Column="3" Text="{Binding ActiveFilter}" FontSize="12"
                       TextColor="{StaticResource Gray400}" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Category Section -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}">
            <HorizontalStackLayout Padding="12,8" Spacing="12">
                <!-- Camera -->
                <Border StrokeShape="RoundRectangle 12" Padding="16,12" MinimumWidthRequest="100"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="camera"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="📷" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Camera" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Gaming -->
                <Border StrokeShape="RoundRectangle 12" Padding="16,12" MinimumWidthRequest="100"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="gaming"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="🎮" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Gaming" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Battery -->
                <Border StrokeShape="RoundRectangle 12" Padding="16,12" MinimumWidthRequest="100"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="battery"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="🔋" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Battery" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Value -->
                <Border StrokeShape="RoundRectangle 12" Padding="16,12" MinimumWidthRequest="100"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="value"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="💰" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Value" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Selfie -->
                <Border StrokeShape="RoundRectangle 12" Padding="16,12" MinimumWidthRequest="100"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="selfie"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="🤳" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Selfie" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                    </VerticalStackLayout>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Recently Viewed Section -->
        <VerticalStackLayout Grid.Row="2" Padding="12,8" Spacing="10" IsVisible="{Binding HasRecentlyViewed}"
                             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">
            <Label Text="Recently Viewed" FontSize="16" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                   Margin="4,0"/>
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding RecentlyViewed}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="services:RecentPhone">
                            <Border StrokeShape="RoundRectangle 10" WidthRequest="100" Padding="6"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type pm:PhoneListPageModel}}, Path=ViewRecentPhoneCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Image Source="{Binding ImageUrl}" HeightRequest="70" Aspect="AspectFit"/>
                                    <Label Text="{Binding Name}" FontSize="10" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                           MaxLines="2" LineBreakMode="TailTruncation" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <!-- Phone Grid (2 columns) -->
        <RefreshView Grid.Row="3" Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}"
                     RefreshColor="{StaticResource Primary}">
            <CollectionView ItemsSource="{Binding Phones}" SelectionMode="None"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                            ItemsLayout="VerticalGrid, 2">
                <CollectionView.EmptyView>
                    <Grid>
                        <!-- Skeleton Loading State -->
                        <Grid RowDefinitions="*,*" ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12" Padding="6"
                              IsVisible="{Binding IsBusy}" VerticalOptions="Start">
                            <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 12" Padding="8"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                                <VerticalStackLayout Spacing="8">
                                    <BoxView HeightRequest="120" CornerRadius="8" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="16" WidthRequest="100" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="12" WidthRequest="60" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A2A}"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 12" Padding="8"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                                <VerticalStackLayout Spacing="8">
                                    <BoxView HeightRequest="120" CornerRadius="8" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="16" WidthRequest="100" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="12" WidthRequest="60" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A2A}"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 12" Padding="8"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                                <VerticalStackLayout Spacing="8">
                                    <BoxView HeightRequest="120" CornerRadius="8" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="16" WidthRequest="100" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="12" WidthRequest="60" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A2A}"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 12" Padding="8"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                                <VerticalStackLayout Spacing="8">
                                    <BoxView HeightRequest="120" CornerRadius="8" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="16" WidthRequest="100" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"/>
                                    <BoxView HeightRequest="12" WidthRequest="60" CornerRadius="4" HorizontalOptions="Center" BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A2A}"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                        <!-- Empty State -->
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                             Padding="40" Spacing="16"
                                             IsVisible="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}">
                            <Label Text="📱" FontSize="48" HorizontalOptions="Center"/>
                            <Label Text="No phones found" FontSize="18" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Select a brand above to browse phones" FontSize="13"
                                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Phone">
                        <Border StrokeShape="RoundRectangle 12" Margin="6" Padding="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pm:PhoneListPageModel}}, Path=ViewPhoneCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="130,Auto,Auto,Auto,Auto" Padding="8">
                                <!-- Phone Image -->
                                <Image Grid.Row="0" Source="{Binding ImageUrl}" Aspect="AspectFit"
                                       HeightRequest="120" HorizontalOptions="Center"
                                       BackgroundColor="Transparent"/>
                                <!-- Favorite Button -->
                                <Button Grid.Row="0" Text="{Binding FavoriteIcon}" FontSize="18"
                                        HorizontalOptions="End" VerticalOptions="Start"
                                        WidthRequest="36" HeightRequest="36" CornerRadius="18"
                                        Padding="0" Margin="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type pm:PhoneListPageModel}}, Path=ToggleFavoriteCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkSurface}}"
                                        TextColor="{StaticResource Primary}">
                                    <Button.Shadow>
                                        <Shadow Brush="{StaticResource BlackBrush}" Offset="0,1" Radius="3" Opacity="0.15"/>
                                    </Button.Shadow>
                                </Button>
                                <!-- Phone Name -->
                                <Label Grid.Row="1" Text="{Binding Name}" FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"
                                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                       MaxLines="2" LineBreakMode="TailTruncation" Margin="0,6,0,2"/>
                                <!-- Brand -->
                                <Label Grid.Row="2" Text="{Binding BrandName}" FontSize="11"
                                       TextColor="{StaticResource Gray400}"
                                       HorizontalOptions="Center" Margin="0,0,0,2"/>
                                <!-- Price -->
                                <Label Grid.Row="3" Text="{Binding PriceDisplay}" FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" Margin="0,0,0,6"/>
                                <!-- Compare Button -->
                                <Button Grid.Row="4" Text="+ Compare" FontSize="11" HeightRequest="32"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type pm:PhoneListPageModel}}, Path=ToggleCompareCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkBackground}}"
                                        TextColor="{StaticResource Primary}"
                                        CornerRadius="8" Padding="8,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Floating Compare Tray -->
        <Border Grid.Row="4" StrokeShape="RoundRectangle 20,20,0,0" Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                IsVisible="{Binding CompareCount, Converter={toolkit:IsNotEqualConverter}, ConverterParameter=0}"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="{StaticResource BlackBrush}" Offset="0,-4" Radius="12" Opacity="0.12"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <!-- Selected phone thumbnails -->
                <HorizontalStackLayout Grid.Column="0" Spacing="-10">
                    <Border WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22"
                            BackgroundColor="{StaticResource Primary}" Stroke="White" StrokeThickness="2">
                        <Label Text="📱" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22"
                            BackgroundColor="{StaticResource Secondary}" Stroke="White" StrokeThickness="2"
                            IsVisible="{Binding CompareCount, Converter={toolkit:IsEqualConverter}, ConverterParameter=2}">
                        <Label Text="📱" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>
                <!-- Compare info -->
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding CompareCount, StringFormat='{0} phone(s) selected'}" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark=White}"/>
                    <Label Text="Tap Compare to see differences" FontSize="11"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="{Binding CanCompare}"/>
                </VerticalStackLayout>
                <!-- Compare button -->
                <Button Grid.Column="2" Text="Compare" Command="{Binding CompareCommand}"
                        IsEnabled="{Binding CanCompare}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        FontSize="13" FontAttributes="Bold" CornerRadius="12"
                        Padding="20,0" HeightRequest="44"/>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
